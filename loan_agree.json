{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finance.internal/schemas/loan-agreement.json",
  "title": "LoanAgreement",
  "type": "object",
  "required": [
    "agreementId",
    "borrower",
    "lenders",
    "loanType",
    "tranches",
    "covenants"
  ],
  "$defs": {
    "legalEntity": {
      "type": "object",
      "required": [
        "name",
        "jurisdiction",
        "regNumber"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "jurisdiction": {
          "type": "string"
        },
        "regNumber": {
          "type": "string"
        },
        "creditRating": {
          "type": "object",
          "properties": {
            "agency": {
              "type": "string",
              "enum": [
                "Moody's",
                "S&P",
                "Fitch",
                "DBRS"
              ]
            },
            "rating": {
              "type": "string"
            },
            "outlook": {
              "type": "string",
              "enum": [
                "stable",
                "positive",
                "negative",
                "watch"
              ]
            }
          }
        }
      }
    },
    "tranche": {
      "type": "object",
      "required": [
        "trancheId",
        "currency",
        "principal",
        "interestType",
        "maturityDate"
      ],
      "properties": {
        "trancheId": {
          "type": "string"
        },
        "currency": {
          "type": "string",
          "pattern": "^[A-Z]{3}$"
        },
        "principal": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "interestType": {
          "type": "string",
          "enum": [
            "fixed",
            "floating",
            "PIK",
            "zero_coupon"
          ]
        },
        "fixedRate": {
          "type": "number",
          "minimum": 0
        },
        "floatingIndex": {
          "type": "string",
          "enum": [
            "SOFR",
            "EURIBOR",
            "SONIA",
            "TONA"
          ]
        },
        "spread": {
          "type": "number"
        },
        "maturityDate": {
          "type": "string",
          "format": "date"
        },
        "ranking": {
          "type": "string",
          "enum": [
            "senior_secured",
            "senior_unsecured",
            "mezzanine",
            "subordinated",
            "equity"
          ]
        },
        "amortization": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "paymentDate",
              "principalPayment",
              "interestPayment"
            ],
            "properties": {
              "paymentDate": {
                "type": "string",
                "format": "date"
              },
              "principalPayment": {
                "type": "number",
                "minimum": 0
              },
              "interestPayment": {
                "type": "number",
                "minimum": 0
              },
              "outstandingBalance": {
                "type": "number",
                "minimum": 0
              }
            }
          },
          "description": "Sum of principalPayment MUST equal principal"
        }
      },
      "if": {
        "properties": {
          "interestType": {
            "const": "fixed"
          }
        }
      },
      "then": {
        "required": [
          "fixedRate"
        ]
      },
      "else": {
        "if": {
          "properties": {
            "interestType": {
              "const": "floating"
            }
          }
        },
        "then": {
          "required": [
            "floatingIndex",
            "spread"
          ]
        }
      }
    },
    "covenant": {
      "type": "object",
      "required": [
        "covenantId",
        "type",
        "metric",
        "threshold"
      ],
      "properties": {
        "covenantId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "financial",
            "informational",
            "affirmative",
            "negative"
          ]
        },
        "metric": {
          "type": "string",
          "examples": [
            "leverage_ratio",
            "interest_coverage",
            "min_liquidity"
          ]
        },
        "threshold": {
          "type": "number"
        },
        "testingFrequency": {
          "type": "string",
          "enum": [
            "monthly",
            "quarterly",
            "semi-annual",
            "annual"
          ]
        },
        "cureRights": {
          "type": "object",
          "properties": {
            "allowed": {
              "type": "boolean"
            },
            "maxCures": {
              "type": "integer",
              "minimum": 1
            },
            "cureAmount": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "collateral": {
      "type": "object",
      "required": [
        "collateralId",
        "type",
        "description",
        "value",
        "lienPriority"
      ],
      "properties": {
        "collateralId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "real_estate",
            "receivables",
            "inventory",
            "IP",
            "securities",
            "guarantee"
          ]
        },
        "description": {
          "type": "string"
        },
        "value": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "valuationDate": {
          "type": "string",
          "format": "date"
        },
        "lienPriority": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  },
  "properties": {
    "agreementId": {
      "type": "string"
    },
    "executionDate": {
      "type": "string",
      "format": "date"
    },
    "borrower": {
      "$ref": "#/$defs/legalEntity"
    },
    "lenders": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "entity",
          "commitmentAmount",
          "commitmentPct"
        ],
        "properties": {
          "entity": {
            "$ref": "#/$defs/legalEntity"
          },
          "commitmentAmount": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "commitmentPct": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "role": {
            "type": "string",
            "enum": [
              "agent",
              "lead",
              "participant"
            ]
          }
        }
      },
      "description": "Sum of commitmentPct MUST equal 100"
    },
    "loanType": {
      "type": "string",
      "enum": [
        "term",
        "revolving",
        "bridge",
        "mezzanine",
        "convertible"
      ]
    },
    "creditFacilityDetails": {
      "type": "object",
      "properties": {
        "maxDrawAmount": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "availabilityPeriod": {
          "type": "integer",
          "minimum": 1
        },
        "cleandownDays": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "tranches": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tranche"
      },
      "description": "Sum of tranches[*].principal MUST equal total facility amount"
    },
    "covenants": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/covenant"
      }
    },
    "collateralRegister": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/collateral"
      }
    },
    "governingLaw": {
      "type": "string"
    },
    "disputeResolution": {
      "type": "string",
      "enum": [
        "arbitration",
        "litigation",
        "mediation"
      ]
    }
  },
  "if": {
    "properties": {
      "loanType": {
        "const": "revolving"
      }
    }
  },
  "then": {
    "required": [
      "creditFacilityDetails"
    ]
  }
}
